# Local PostgreSQL configuration. These are development-only values.
POSTGRES_DB=stocklens
POSTGRES_USER=stocklens
POSTGRES_PASSWORD=stocklens_dev
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/stocklens

# Local Redis configuration.
SPRING_DATA_REDIS_HOST=localhost

# Optional frontend API origin override. Local Vite development uses its proxy.
# Export this for the frontend process only when the API is on another origin.
VITE_API_BASE_URL=

# Financial Modeling Prep. Keep the API key blank in committed files.
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable
FMP_CONNECT_TIMEOUT=2s
FMP_READ_TIMEOUT=5s
FMP_MAX_ATTEMPTS=2

# Yahoo Finance recent news. This unofficial MVP path does not use an API key.
YAHOO_FINANCE_BASE_URL=https://finance.yahoo.com
YAHOO_FINANCE_CONNECT_TIMEOUT=2s
YAHOO_FINANCE_READ_TIMEOUT=5s
YAHOO_FINANCE_MAX_ATTEMPTS=2

# OpenAI comparison brief. A ChatGPT subscription is not an API credential.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_BASE_URL=https://api.openai.com/v1
AI_COMPARISON_TEMPERATURE=0.2
AI_COMPARISON_MAX_TOKENS=1200

# Cache TTL overrides. Redis is best-effort; PostgreSQL remains durable.
STOCKLENS_CACHE_COMPANY_TTL=24h
STOCKLENS_CACHE_MARKET_TTL=15m
STOCKLENS_CACHE_METRICS_TTL=6h
STOCKLENS_CACHE_HISTORY_TTL=6h
STOCKLENS_CACHE_NEWS_TTL=30m
STOCKLENS_CACHE_COMPARISON_TTL=15m
STOCKLENS_CACHE_BRIEF_TTL=1h
